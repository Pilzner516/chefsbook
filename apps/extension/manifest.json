{
  "manifest_version": 3,
  "name": "Chefsbook",
  "description": "Save any recipe to your Chefsbook with one click",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["http://localhost:3000/*", "http://100.110.47.62:8000/*"]
}
