{
  "manifest_version": 3,
  "name": "ChefsBook — Save Recipes",
  "description": "Save recipes from any webpage directly to your ChefsBook collection with one click. Handles bot-protected sites automatically.",
  "version": "1.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    },
    "default_title": "Save to ChefsBook"
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://chefsbk.app/*", "https://www.chefsbk.app/*"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["activeTab", "tabs", "storage", "scripting"],
  "host_permissions": ["https://chefsbk.app/*", "https://api.chefsbk.app/*", "<all_urls>"]
}
