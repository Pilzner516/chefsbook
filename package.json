{
  "name": "chefsbook",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "mobile": "turbo dev --filter=@chefsbook/mobile",
    "web": "turbo dev --filter=@chefsbook/web"
  },
  "packageManager": "npm@11.8.0",
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native-worklets": "^0.8.1"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "5.9.2"
  }
}
